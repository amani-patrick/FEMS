# ── FEMCS root .env — copy to .env and fill in real values ─────────────────
# docker-compose reads this automatically

# JWT — change this to a long random string in production
JWT_SECRET=femcs_jwt_super_secret_change_in_production

# SMTP — used by auth-service (OTP), extinguisher-service, notification-service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_app_email@gmail.com
SMTP_PASS=your_app_password_here

EMAIL_FROM=FEMCS System <noreply@femcs.rw>
